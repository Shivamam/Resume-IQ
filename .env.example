############################
# DATABASE (Docker service)
############################
MYSQL_ROOT_PASSWORD=strong_mysql_root_password
MYSQL_DATABASE=resumeiq_db

DATABASE_URL=mysql+mysqldb://root:${MYSQL_ROOT_PASSWORD}@resumeiq-db:3306/${MYSQL_DATABASE}


############################
# AUTH / JWT
############################
JWT_SECRET_KEY=replace_with_long_random_secret
JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7


############################
# REDIS (Docker service)
############################
REDIS_URL=redis://resumeiq-redis:6379/0

CELERY_BROKER_URL=redis://resumeiq-redis:6379/1
CELERY_RESULT_BACKEND=redis://resumeiq-redis:6379/2

WS_REDIS_URL=redis://resumeiq-redis:6379/3


############################
# OTP
############################
OTP_EXPIRE_SECONDS=300


############################
# EMAIL (FastAPI-Mail + Gmail SMTP)
############################
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_gmail_app_password
MAIL_FROM=your_email@gmail.com
MAIL_FROM_NAME=ResumeIQ

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

MAIL_STARTTLS=True
MAIL_SSL_TLS=False


############################
# CLOUDINARY
############################
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


############################
# GROQ
############################
GROQ_API_KEY=your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
